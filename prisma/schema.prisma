// ADNTmarket.app - Multi-Tenant POS Platform
// Schema: Setiap toko (tenant) memiliki data terisolasi via tenantId

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH / USER ───────────────────────────────────────────

// UserRole: SUPER_ADMIN | TENANT_ADMIN | KASIR

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  nama          String
  role          String    @default("KASIR")
  isActive      Boolean   @default(true)
  tenantId      String?   // null untuk SUPER_ADMIN

  // Relasi
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@map("users")
}

// ─── TENANT / TOKO ─────────────────────────────────────────

// TenantStatus: AKTIF | SUSPENDED | NONAKTIF

model Tenant {
  id              String       @id @default(cuid())
  slug            String       @unique // identifier unik di URL (contoh: "tokopakkris")
  namaToko        String
  alamat          String?
  telepon         String?
  statusAktif     Boolean      @default(true)
  status          String    @default("AKTIF")
  tanggalMulai    DateTime     @default(now())
  tanggalKedaluwarsa DateTime?
  logoUrl         String?
  catatan         String?

  // Relasi
  users           User[]
  products        Product[]
  customers       Customer[]
  transactions    Transaction[]
  settings        Setting?
  payments        Payment[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([slug])
  @@index([statusAktif])
  @@map("tenants")
}

// ─── PRODUK ────────────────────────────────────────────────

// KategoriProduk: MAKANAN | MINUMAN | SEMBAKO | SNACK | MINYAK | BERAS | GULA | TELUR | SUSU | ROKOK | OBAT | ALAT_TULIS | KEBERSIHAN | LAINNYA

model Product {
  id            String         @id @default(cuid())
  tenantId      String
  nama          String
  barcode       String?        @unique // kode barcode produk
  kategori      String        @default("LAINNYA")
  hargaJual     Int            @default(0) // dalam Rupiah (integer, hindari float)
  hargaModal    Int            @default(0)
  stok          Int            @default(0)
  satuan        String         @default("pcs") // pcs, kg, liter, dll
  isActive      Boolean        @default(true)
  gambarUrl     String?

  // Relasi
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  transactionDetails TransactionDetail[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, barcode])
  @@index([tenantId, nama])
  @@map("products")
}

// ─── PELANGGAN ─────────────────────────────────────────────

model Customer {
  id          String    @id @default(cuid())
  tenantId    String
  nama        String
  telepon     String?
  alamat      String?
  poin        Int       @default(0)

  // Relasi
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  transactions Transaction[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, nama])
  @@map("customers")
}

// ─── TRANSAKSI ─────────────────────────────────────────────

// MetodePembayaran: TUNAI | QRIS | TRANSFER | DEBIT | LAINNYA

model Transaction {
  id              String           @id @default(cuid())
  tenantId        String
  customerId      String?
  kodeTransaksi   String           @unique // format: INV/YYYYMMDD/XXXXX
  totalBelanja    Int              @default(0) // dalam Rupiah
  totalModal      Int              @default(0)
  labaKotor       Int              @default(0)
  nominalBayar    Int              @default(0)
  kembalian       Int              @default(0)
  metodePembayaran String       @default("TUNAI")
  diskon          Int          @default(0)
  catatan         String?
  status          Boolean          @default(true) // true=berhasil, false=batal

  // Relasi
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  details         TransactionDetail[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([kodeTransaksi])
  @@map("transactions")
}

model TransactionDetail {
  id              String      @id @default(cuid())
  transactionId   String
  tenantId        String
  productId       String
  namaProduk      String      // snapshot nama produk saat transaksi
  hargaJual       Int         @default(0) // snapshot harga jual
  hargaModal      Int         @default(0) // snapshot harga modal
  qty             Int         @default(1)
  subtotal        Int         @default(0) // qty * hargaJual
  subtotalModal   Int         @default(0) // qty * hargaModal

  // Relasi
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  product         Product?    @relation(fields: [productId, tenantId], references: [id, tenantId])

  createdAt       DateTime    @default(now())

  @@index([transactionId])
  @@index([tenantId])
  @@map("transaction_details")
}

// ─── PENGATURAN TOKO ───────────────────────────────────────

model Setting {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  footerStruk       String?  @default("Terima kasih telah berbelanja")
  headerStruk       String?
  pajakPersen       Float?   @default(0)
  cetakStrukOtomatis Boolean @default(true)

  // Relasi
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@map("settings")
}

// ─── SUBSCRIPTION / SEWA ─────────────────────────────────────

model SubscriptionPlan {
  id            String    @id @default(cuid())
  nama          String    // "1 Bulan", "3 Bulan", "1 Tahun"
  durasiHari    Int       // 30, 90, 365
  harga         Int       // dalam Rupiah
  deskripsi     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@map("subscription_plans")
}

model Payment {
  id              String   @id @default(cuid())
  tenantId        String
  planId          String
  amount          Int      // dalam Rupiah
  status          String   @default("PENDING") // PENDING | SETTLED | EXPIRED | FAILED
  metodePembayaran String? // bank_transfer, gopay, qris, dll
  merchantOrderId String   @unique
  transactionId   String?  // dari Midtrans
  snapToken       String?  // Midtrans Snap token
  paidAt          DateTime?
  expiredAt       DateTime?
  pembeliNama     String?
  pembeliEmail    String?
  pembeliTelepon  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  plan            SubscriptionPlan  @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([merchantOrderId])
  @@map("payments")
}

// Tambah relasi ke Tenant
// Payment[] udah otomatis dari `tenant` field di atas
